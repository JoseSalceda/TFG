@startuml Administrador
top to bottom direction
skinparam packageStyle rectangle

actor "Administrador" as Admin

rectangle "Sistema Theia Officer - Modulo FinOps AWS" {
  rectangle "Plataforma base (Theia Craft)" {
    usecase "CU-01\nRegistrar credenciales AWS" as CU01
    usecase "CU-02\nDescubrir agentes en AWS" as CU02
    usecase "CU-04\nAutenticarse" as CU04
    usecase "CU-05\nConfigurar proveedor LLM" as CU05
    usecase "CU-06\nAuditoria de actividad" as CU06
  }
  rectangle "Nuevas misiones FinOps (TFG)" {
    usecase "CU-07\nDashboard consolidado de costes IA" as CU07
    usecase "CU-08\nDetectar anomalias de gasto" as CU08
    usecase "CU-09\nAnalizar eficiencia de agentes" as CU09
    usecase "CU-10\nVisibilidad coste LLM plataforma" as CU10
    usecase "CU-11\nRecomendar optimizacion de modelo" as CU11
    usecase "CU-12\nProyectar tendencia de costes" as CU12
    usecase "CU-13\nConfigurar alertas de umbral" as CU13
    usecase "CU-14\nInforme de consumo IA" as CU14
    usecase "CU-15\nConsolidacion de agentes" as CU15
  }
}

Admin --> CU01
Admin --> CU02
Admin --> CU04
Admin --> CU05
Admin --> CU06
Admin --> CU07
Admin --> CU08
Admin --> CU09
Admin --> CU10
Admin --> CU11
Admin --> CU12
Admin --> CU13
Admin --> CU14
Admin --> CU15

@enduml
